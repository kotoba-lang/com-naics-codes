// Naics_codes clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace naics_codes {

    entity Code {
        id: string @unique
        code: string
        description: string
        scheme: string
        parentCode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Unit {
        id: string @unique
        symbol: string
        name: string
        quantity: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Reference {
        id: string @unique
        name: string
        value: float
        uncertainty: float
        unit: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Mapping {
        id: string @unique
        fromCode: string
        toScheme: string
        toCode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Location {
        id: string @unique
        unLocode: string
        name: string
        country: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Epoch {
        id: string @unique
        name: string
        utcOffset: string
        asOf: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
